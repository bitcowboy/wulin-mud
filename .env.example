# ============================================================
# wulin-mud · environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.
# ============================================================

# ---- LLM provider ----
# Default provider for v0.1 is OpenAI.
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Models used in different roles. See docs/llm-integration.md section 4.
WULIN_MODEL_DIALOGUE=gpt-4o
WULIN_MODEL_MEMORY=gpt-4o-mini
WULIN_MODEL_DECISION=gpt-4o-mini
WULIN_MODEL_INTENT=gpt-4o-mini

# ---- Database ----
# v0.1 uses SQLite. The file lives under ./var/ by default.
WULIN_DB_URL=sqlite:///./var/wulin.db

# ---- World ----
# How many real seconds equal one game minute.
# Default: 6 (i.e. 1 real minute = 10 game minutes)
WULIN_TIME_RATIO=6

# How often the world tick runs, in real seconds.
WULIN_TICK_INTERVAL=300

# ---- Logging ----
WULIN_LOG_LEVEL=INFO
WULIN_LOG_DIR=./var/logs

# ---- Debug ----
# When true, prints LLM prompts and responses to stderr.
WULIN_DEBUG_LLM=false
# When true, slows down LLM calls to reduce token spend in dev.
WULIN_DEV_MODE=true
